{
  "name": "example-angular-21-app",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "ng build",
    "lint": "ng lint",
    "ng": "ng",
    "prepare": "husky",
    "start": "ng serve",
    "test": "ng test",
    "watch": "ng build --watch --configuration development"
  },
  "lint-staged": {
    "*.{css,html,js,jsx,json,md,scss,ts,tsx,yaml,yml}": [
      "prettier --write"
    ],
    "src/**/*.{html,js,jsx,ts,tsx}": [
      "ng-lint-staged lint --fix --"
    ]
  },
  "dependencies": {
    "@angular/cdk": "^21",
    "@angular/common": "^21",
    "@angular/compiler": "^21",
    "@angular/core": "^21",
    "@angular/forms": "^21",
    "@angular/material": "^21",
    "@angular/platform-browser": "^21",
    "@angular/router": "^21",
    "rxjs": "^7",
    "tslib": "^2"
  },
  "devDependencies": {
    "@angular/build": "^21",
    "@angular/cli": "^21",
    "@angular/compiler-cli": "^21",
    "@eslint/js": "^10",
    "angular-eslint": "21",
    "eslint": "^10",
    "jsdom": "^28",
    "lint-staged": "^16",
    "ng-lint-staged": "^12",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^4"
  },
  "packageManager": "npm@11.6.1",
  "engines": {
    "node": "^24",
    "npm": "^11"
  }
}
